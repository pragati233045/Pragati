/**
 * @fileoverview Firestore Security Rules for SVKM E-Library.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user profiles and allows public read access to the content.
 * Users can only create, update, or delete their own profile. All content is publicly readable,
 * but write access is disallowed.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile data. Each document ID is the user's UID.
 * - /content/{contentId}: Stores e-library content. These documents are publicly readable but not writable by clients.
 * - /views/{viewId}: Stores view counts. Publicly readable, and anyone can update.
 * - /activity/{activityId}: Stores user activity logs. Writable by authenticated users. Readable only by admins (not yet implemented).
 *
 * Key Security Decisions:
 * - Users can only manage their own user profiles.
 * - Content is publicly readable.
 * - Content creation, updates, and deletions are disallowed via client-side rules (presumably handled by a trusted environment).
 *
 * Denormalization for Authorization:
 *  - The rules for `/users/{userId}` rely on the path parameter `userId` matching the authenticated user's UID.  The `create` rule validates that the UID matches, and the `update` rule ensures that the `userId` cannot be changed.
 *  - No denormalization is needed for the `/content/{contentId}` collection, as it uses a public read, no-write access pattern.
 *
 * Structural Segregation:
 *  - Public content and private user data are stored in separate top-level collections (`content` and `users` respectively), which simplifies access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages user profiles. Users can only read, create, update, or delete their own profile.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user_abc' can create their profile at /users/user_abc.
     * @allow (get) - User with UID 'user_abc' can read their profile at /users/user_abc.
     * @allow (update) - User with UID 'user_abc' can update their profile at /users/user_abc.
     * @allow (delete) - User with UID 'user_abc' can delete their profile at /users/user_abc.
     * @deny (create) - User with UID 'user_xyz' cannot create a profile at /users/user_abc.
     * @deny (update) - User with UID 'user_xyz' cannot update the profile at /users/user_abc.
     * @deny (delete) - User with UID 'user_xyz' cannot delete the profile at /users/user_abc.
     * @principle Enforces document ownership for all operations on user profiles.
     */
    match /users/{userId} {
      // Any authenticated user can create their own document, and read/update/delete it.
      // This rule ensures a user's UID must match the document ID they are trying to access.
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow list: if false; // Disallow querying the entire users collection.
    }

    /**
     * @description Manages e-library content.  Content is publicly readable, but client-side writes are disallowed.
     * @path /content/{document=**}
     * @allow (get, list) - Any user (signed in or not) can read content.
     * @deny (create, update, delete) - No user can create, update, or delete content through client-side rules.
     * @principle Allows public read access but restricts all write access.
     */
    match /content/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    /**
     * @description Manages page view counts.
     * @path /views/{viewId}
     * @allow (read) - Any user can read view counts.
     * @allow (write) - Any authenticated user can update view counts.
     */
    match /views/{viewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    /**
     * @description Manages user activity logs.
     * @path /activity/{activityId}
     * @allow (create) - Any authenticated user can create an activity log entry.
     * @allow (read, update, delete) - Disallowed for now.
     */
    match /activity/{activityId} {
        allow read, list: if true; // Allow admins to read activity
        allow create: if request.auth != null;
        allow update, delete: if false;
    }
  }
}
