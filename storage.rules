rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to write to the 'content' folder.
    match /content/{allPaths=**} {
      allow write: if request.auth != null;
    }

    // Allow public read access to all files.
    match /{allPaths=**} {
      allow read: if true;
    }
  }
}
